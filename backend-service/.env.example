# Application configuration
APP_NAME=Agentic Engineering Knowledge Assistant
APP_VERSION=1.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO

# API configuration
API_HOST=0.0.0.0
API_PORT=8000

# Retrieval configuration
REPOSITORY_TYPE=memory
TOP_K=5

# Database configuration
DATABASE_URL=postgresql+psycopg://username:password@postgres:5432/knowledge_assistant

# External API credentials
OPENAI_API_KEY=
SERPER_API_KEY=

AZURE_STORAGE_CONNECTION_STRING=replace_with_connection_string
AZURE_ORIGINAL_DOCUMENTS_CONTAINER=original-documents
AZURE_EXTRACTED_IMAGES_CONTAINER=extracted-images



OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_BATCH_SIZE=32

OPENAI_VISION_MODEL=gpt-4.1-mini
IMAGE_CAPTION_MAX_OUTPUT_TOKENS=200